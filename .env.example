DROPBOX_TOKEN=your_dropbox_api_token_here
DROPBOX_FOLDER=C:\Users\you\Didac\Dropbox\Apps\your-app-folder

SSH_HOST=your-server.com
SSH_USER=root
SSH_PASSWORD=your_ssh_password_here
# SSH_KEY_PATH=C:\Users\you\.ssh\id_rsa.pem  (optional, use instead of or alongside SSH_PASSWORD)
SSH_REMOTE_PATH=/var/www/autopodcast/feed.xml

